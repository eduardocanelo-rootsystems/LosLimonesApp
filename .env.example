# ─────────────────────────────────────────────────────────────────
# Configuración de Supabase
# ─────────────────────────────────────────────────────────────────
# Obtené estos valores en: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Los Limones Creativos

# ─────────────────────────────────────────────────────────────────
# Para Edge Functions (NO se exponen al cliente — sin prefijo VITE_)
# Configurar directamente en Supabase Dashboard > Settings > Edge Functions
# ─────────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# EMAIL_FROM=noreply@loslimones.com.ar
# ARCA_HOMOLOGACION=true
